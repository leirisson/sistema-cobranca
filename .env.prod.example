# Variáveis para o docker-compose.prod.yml (deploy na VPS)
# Copiar para `.env` na raiz do projeto e preencher com valores reais.
# Nunca commitar o `.env` real.

# Postgres
POSTGRES_USER=cobracerta
POSTGRES_PASSWORD=
POSTGRES_DB=cobracerta

# Redis
REDIS_PASSWORD=
# Índice do banco Redis (0-15). Só precisa mudar se este Redis for compartilhado com outro
# projeto/app na mesma instância — nesse caso, use um índice que não colida com o que o outro
# projeto já usa (ex: a Evolution API deste projeto usa o índice 6, ver docker-compose.prod.yml).
REDIS_DB=0

# Evolution API (WhatsApp)
# URL pública/acessível da própria instância Evolution (usada por ela mesma para callbacks)
EVOLUTION_SERVER_URL=https://evolution.seu-dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=cobracerta

# Asaas (gateway de pagamento) — produção, não sandbox
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# Gmail (e-mail de cobrança, Nodemailer + senha de app)
GMAIL_USUARIO=
GMAIL_SENHA_APP=
GMAIL_REMETENTE=

# Regras de negócio
COBRANCA_ANTECEDENCIA_DIAS=5
CONFIRMACAO_PAGAMENTO_HABILITADA=false

# Autenticação (JWT)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Configurações (ONB) — cifragem em repouso da chave Asaas salva pela tela
# 64 caracteres hex (32 bytes): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# Segurança (SEC) — origem pública do frontend, separadas por vírgula se houver mais de uma
CORS_ALLOWED_ORIGINS=https://app.seu-dominio.com

# Observabilidade (OBS) — opcional
ALERTA_OPERACIONAL_DESTINO=
ALERTA_GMAIL_USUARIO=
ALERTA_GMAIL_SENHA_APP=
ALERTA_GMAIL_REMETENTE=

# Seed do super administrador — rodar manualmente uma vez após o primeiro deploy, dentro do
# container da API: node dist/infra/database/seed-admin.js
# Único usuário do sistema (single-tenant, AUTH-02) — sem tela de cadastro.
SEED_ADMIN_EMAIL=
SEED_ADMIN_SENHA=

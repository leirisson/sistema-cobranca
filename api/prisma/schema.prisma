generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusCliente {
  ATIVO
  INATIVO

  @@map("status_cliente")
}

enum StatusCobranca {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO

  @@map("status_cobranca")
}

enum TipoMensagem {
  LEMBRETE
  VENCIMENTO
  ATRASO
  CONFIRMACAO

  @@map("tipo_mensagem")
}

enum CanalNotificacao {
  whatsapp
  email

  @@map("canal_notificacao")
}

model Cliente {
  id                String         @id @default(uuid())
  nome              String
  email             String?
  documento         String
  valorCobranca     Decimal        @map("valor_cobranca") @db.Decimal(10, 2)
  diaVencimento     Int            @map("dia_vencimento")
  status            StatusCliente  @default(ATIVO)
  inscricaoEstadual String?        @map("inscricao_estadual")
  enderecoRua       String?        @map("endereco_rua")
  enderecoNumero    String?        @map("endereco_numero")
  enderecoBairro    String?        @map("endereco_bairro")
  enderecoCidade    String?        @map("endereco_cidade")
  enderecoUf        String?        @map("endereco_uf")
  enderecoCep       String?        @map("endereco_cep")
  nomeContato       String?        @map("nome_contato")
  referenciaServico String?        @map("referencia_servico")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  telefones TelefoneCliente[]
  cobrancas Cobranca[]

  @@map("clientes")
}

model TelefoneCliente {
  id        String  @id @default(uuid())
  clienteId String  @map("cliente_id")
  numero    String
  principal Boolean @default(false)

  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
  @@map("telefones_cliente")
}

model Cobranca {
  id               String         @id @default(uuid())
  clienteId        String         @map("cliente_id")
  valor            Decimal        @db.Decimal(10, 2)
  vencimento       DateTime       @db.Date
  status           StatusCobranca @default(PENDENTE)
  gatewayChargeId  String?        @unique @map("gateway_charge_id")
  linkPagamento    String?        @map("link_pagamento")
  paidAt           DateTime?      @map("paid_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  cliente           Cliente            @relation(fields: [clienteId], references: [id])
  mensagensEnviadas MensagemEnviada[]

  @@index([clienteId])
  @@index([status])
  @@map("cobrancas")
}

model MensagemEnviada {
  id           String            @id @default(uuid())
  cobrancaId   String            @map("cobranca_id")
  tipo         TipoMensagem
  enviadoEm    DateTime          @default(now()) @map("enviado_em")
  statusEnvio  String            @map("status_envio")
  canal        CanalNotificacao  @default(whatsapp)

  cobranca Cobranca @relation(fields: [cobrancaId], references: [id])

  @@index([cobrancaId])
  @@map("mensagens_enviadas")
}

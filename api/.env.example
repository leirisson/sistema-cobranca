# App
NODE_ENV=development
PORT=3000

# Banco de dados
DATABASE_URL=postgresql://cobracerta:cobracerta@localhost:5433/cobracerta

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Asaas (gateway de pagamento)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Evolution API (WhatsApp)
# Sobe via docker-compose (serviço evolution-api, porta 8080); EVOLUTION_API_KEY deve bater com
# AUTHENTICATION_API_KEY do serviço evolution-api no docker-compose.yml
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=cobracerta

# Gmail (e-mail, Nodemailer + senha de app - EMAIL-02)
GMAIL_USUARIO=
GMAIL_SENHA_APP=
GMAIL_REMETENTE=

# Regras de negócio
COBRANCA_ANTECEDENCIA_DIAS=5
CONFIRMACAO_PAGAMENTO_HABILITADA=false

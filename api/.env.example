# Gmail API (e-mail, OAuth2 - EMAIL-02)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REMETENTE=

# Regras de negócio
COBRANCA_ANTECEDENCIA_DIAS=5
CONFIRMACAO_PAGAMENTO_HABILITADA=false

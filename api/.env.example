# App
NODE_ENV=development
PORT=3000

# Banco de dados
DATABASE_URL=postgresql://cobracerta:cobracerta@localhost:5433/cobracerta

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
# Índice do banco Redis (0-15). Só precisa mudar se essa instância Redis for compartilhada
# com outro projeto/app — nesse caso, use um índice que não colida com o que o outro projeto
# já usa (ex: a própria Evolution API deste projeto usa o índice 6, ver docker-compose.yml).
REDIS_DB=0

# Asaas (gateway de pagamento)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Evolution API (WhatsApp)
# Sobe via docker-compose (serviço evolution-api, porta 8080); EVOLUTION_API_KEY deve bater com
# AUTHENTICATION_API_KEY do serviço evolution-api no docker-compose.yml
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=cobracerta

# Gmail (e-mail, Nodemailer + senha de app - EMAIL-02)
GMAIL_USUARIO=
GMAIL_SENHA_APP=
GMAIL_REMETENTE=

# Regras de negócio
COBRANCA_ANTECEDENCIA_DIAS=5
CONFIRMACAO_PAGAMENTO_HABILITADA=false

# Autenticação (JWT)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Configurações (ONB) — cifragem em repouso da chave Asaas salva pela tela
# 64 caracteres hex (32 bytes), ex: gerado com `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
CONFIG_ENCRYPTION_KEY=

# Segurança (SEC) — origens do frontend permitidas por CORS, separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Observabilidade (OBS) — opcional. Telefone E.164 (WhatsApp) ou e-mail do usuário para
# receber alerta quando o job de geração de cobrança ou a régua de atraso falhar. Se ausente,
# a falha só é logada (comportamento atual).
ALERTA_OPERACIONAL_DESTINO=

# Observabilidade (OBS) — remetente Gmail dedicado ao alerta, separado do Gmail que envia
# cobrança/lembrete aos clientes (GMAIL_USUARIO acima). Opcionais: se qualquer um ausente,
# o alerta usa o mesmo Gmail de cobrança como fallback (só o destinatário muda).
ALERTA_GMAIL_USUARIO=
ALERTA_GMAIL_SENHA_APP=
ALERTA_GMAIL_REMETENTE=

# Seed do super administrador (npm run seed:admin / node dist/infra/database/seed-admin.js)
# Único usuário do sistema (single-tenant, AUTH-02) — sem tela de cadastro.
SEED_ADMIN_EMAIL=
SEED_ADMIN_SENHA=
